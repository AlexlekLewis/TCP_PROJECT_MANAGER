# Client (safe to expose — these are public by design)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Demo mode — when true, app uses in-memory fixtures and skips Supabase entirely.
# Useful for local UI preview without a Supabase project.
VITE_DEMO_MODE=true

# Optional — Sentry frontend DSN
VITE_SENTRY_DSN=

# ============================================================================
# Server-side only — NEVER commit real values. Set via `supabase secrets set`
# ============================================================================
# ANTHROPIC_API_KEY=sk-ant-...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# RESEND_API_KEY=re_...
